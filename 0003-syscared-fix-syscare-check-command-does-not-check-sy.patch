-    pub fn active(&mut self, patch: &Patch, flag: PatchOpFlag) -> Result<()> {
+    pub fn active_patch(&mut self, patch: &Patch, flag: PatchOpFlag) -> Result<()> {
+        if flag != PatchOpFlag::Force {
