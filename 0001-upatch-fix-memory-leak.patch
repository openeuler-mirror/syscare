+        goto out;
     }
 
     int offset = snprintf(err_msg, max_len, "Patch is conflicted with ");
@@ -39,50 +61,78 @@ int upatch_check(const char *target_elf, const char *patch_file, char *err_msg,
         offset = snprintf(err_msg, max_len, "\"%s\" ", collision->uuid);
     }
 
