+                    (((uelf->arch == X86_64) && (rela->type == R_X86_64_32S || rela->type == R_X86_64_32)) ||
+                     ((uelf->arch == AARCH64) && (rela->type == R_AARCH64_ABS64)) ||
+                     ((uelf->arch == RISCV64) && (rela->type == R_RISCV_64))) &&
